{
  "expo": {
    "name": "책쏙",
    "slug": "booksok",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "booksok",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.booksok.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.booksok.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-audio",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF7340"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "사진 기록을 저장하기 위해 앨범 접근 권한이 필요해요.",
          "cameraPermission": "사진을 찍어 기록하기 위해 카메라 권한이 필요해요."
        }
      ],
      "expo-asset",
      "expo-dev-client",
      "react-native-purchases"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
